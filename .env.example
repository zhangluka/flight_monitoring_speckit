# 航班搜索数据源（002-real-api-integration）
# 见 specs/002-real-api-integration/contracts/data-source-config.md

# 数据源模式：mock | real；未设置或无效时视为 mock
# FLIGHT_DATA_SOURCE=mock

# 以下仅当 FLIGHT_DATA_SOURCE=real 时生效
# 真实航班 API 的 base URL（以供应商文档为准）
# FLIGHT_API_BASE_URL=https://api.example.com
# 真实 API 密钥（勿提交版本库）
# FLIGHT_API_KEY=your_api_key
